{
  "name": "budget",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names \"server,app\" --prefix-colors \"yellow,cyan\" \"bun run --cwd packages/server dev\" \"bun run --cwd packages/app dev\"",
    "dev:app": "bun run --cwd packages/app dev",
    "dev:server": "bun run --cwd packages/server dev",
    "build": "bun run --cwd packages/app build",
    "preview": "bun run --cwd packages/app preview"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
