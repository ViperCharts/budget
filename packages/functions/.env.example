# Plaid API credentials — for local emulator development only.
# In production, set these via Firebase CLI:
#   firebase functions:config:set plaid.client_id="..." plaid.secret="..." plaid.env="sandbox"
#
# Get credentials from https://dashboard.plaid.com/team/keys
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_sandbox_secret_here
PLAID_ENV=sandbox
